# Local development env for `next dev` / `next build`.
# Copy to `.env` (gitignored) and fill in real values.
# See docs/environment.md for what each value is and where it comes from.
#
# In CI (deploy.yml) most of these are DERIVED at deploy time: the Convex URL
# and app key come from the Convex deployment (via CONVEX_DEPLOY_KEY), and the
# Clerk publishable key from the hostname in deploy.config.json. This file is
# for local dev only, pointing at your DEV Clerk/Convex instances.

# --- Server secrets (never commit real values) ---
# Shared app auth key; must equal the `API_KEY` env var in the Convex
# deployment you point at below (dev: set it in the dev Convex dashboard;
# prod's is auto-generated per deploy — `npx convex env get API_KEY`).
CONVEX_API_KEY=""
# Clerk dashboard -> API keys -> Secret key (use your dev instance's sk_test_ key).
CLERK_SECRET_KEY=""

# --- Client (build-time, inlined into the bundle) ---
# Convex deployment URL (dev deployment for local work).
NEXT_PUBLIC_CONVEX_URL=""
# Google Cloud console -> Maps Platform.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_MAP_ID=""
# Clerk dashboard -> API keys -> Publishable key (pk_test_ for dev).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# Optional; verbose client logging. Defaults to false.
NEXT_PUBLIC_LOG_VERBOSE="false"
