# firstdue-listener environment
#
# Local dev: copy this file to `.env` and fill in real values (.env is
# gitignored). In production these are provided by the Cloudflare Worker:
#   - non-secret values live in wrangler.jsonc `vars`
#   - secrets are set with `wrangler secret put <NAME>` (see README)
# The listener validates all of these on boot (zod) and exits(1) if a required
# var is missing or invalid.

# --- Runtime (all optional, sensible defaults shown) ---
# development | production | test  (default: development)
NODE_ENV=development
# HTTP port the listener binds to (default: 8080)
PORT=8080
# IANA timezone used for log timestamps and formatting (default: America/Chicago)
TIMEZONE=America/Chicago
# error | warn | info | timer | debug | verbose
# (default: debug when NODE_ENV=development, otherwise info)
LOG_LEVEL=debug

# --- First Due API (required, secret) ---
FIRSTDUE_API_KEY=

# --- Weather API (required) ---
# WEATHER_API_KEY is secret; LAT/LNG/UNITS are non-secret (set as Worker vars)
WEATHER_API_KEY=
WEATHER_LAT=
WEATHER_LNG=
# imperial | metric (default: imperial)
WEATHER_UNITS=imperial

# --- Convex (CONVEX_URL non-secret, CONVEX_API_KEY secret) ---
CONVEX_URL=
CONVEX_API_KEY=

# --- API auth (optional, secret) ---
# Gates the HTTP API and WebSocket via `?API_KEY=...`. If unset the listener
# runs fully open and logs a warning on every request.
API_KEY=
