{
  "name": "@sizeupdashboard/firstdue-listener",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p worker/tsconfig.json",
    "docker:build": "docker build -f Dockerfile -t firstdue-listener ../..",
    "docker:run": "docker run --rm --env-file .env -p 8080:8080 firstdue-listener",
    "cf:deploy": "wrangler deploy",
    "cf:dev": "wrangler dev",
    "cf:types": "wrangler types"
  },
  "license": "ISC",
  "dependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@sizeupdashboard/convex": "workspace:*",
    "chalk": "^5.4.1",
    "convex": "^1.25.4",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-winston": "^4.2.0",
    "moment-timezone": "^0.6.0",
    "winston": "^3.17.0",
    "ws": "^8.18.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@sizeupdashboard/eslint-config": "workspace:*",
    "@sizeupdashboard/typescript-config": "workspace:*",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/ws": "^8.5.12",
    "eslint": "^9.23.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.107.0"
  }
}
