{
  "name": "${localWorkspaceFolderBasename} — Nix Dev Environment",
  "build": {
    "context": ".",
    "dockerfile": "Dockerfile"
  },

  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  "mounts": ["source=lunarhue-containers-nix-store,target=/nix,type=volume"],

  "containerEnv": {
    "NIX_CONFIG": "experimental-features = nix-command flakes"
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "vscode",
      "uid": "1000",
      "gid": "1000",
      "installZsh": false,
      "installOhMyZsh": false,
      "configureZshAsDefaultShell": false
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "false"
    }
  },

  "postCreateCommand": "bash .devcontainer/create.sh",
  "postStartCommand": "bash .devcontainer/start.sh",

  "customizations": {
    "vscode": {
      "extensions": ["mkhl.direnv", "jnoortheen.nix-ide", "hashicorp.terraform"]
    }
  },
  "forwardPorts": [3000],
  "remoteUser": "vscode"
}
