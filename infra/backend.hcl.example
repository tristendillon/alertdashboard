# Partial backend configuration for the R2 (S3-compatible) state backend.
#
# Copy this file to `backend.hcl` (gitignored) and fill in your Cloudflare account id,
# then run:
#
#   tofu init -backend-config=backend.hcl
#
# Credentials are supplied via the environment, NOT this file:
#   export AWS_ACCESS_KEY_ID=<R2 access key id>
#   export AWS_SECRET_ACCESS_KEY=<R2 secret access key>
#
# See infra/README.md for the R2 bucket + access-key bootstrap.

endpoints = { s3 = "https://<ACCOUNT_ID>.r2.cloudflarestorage.com" }
